algoritmo "Problema Media Idades"

var

  senhaFix, senhaVar : inteiro

inicio
  senhaFix <- 2002

  escreval("Digite a senha: ")

  leia(senhaVar)

  se senhaVar = senhaFix entao

    escreval("Acesso permitido!")

  senao

    enquanto senhaFix <> senhaVar faca

      escreval("Senha invalida! Tente novamente:")
      leia(senhaVar)

    fimenquanto

    escreval("Acesso permitido!")

  fimse

fimalgoritmo
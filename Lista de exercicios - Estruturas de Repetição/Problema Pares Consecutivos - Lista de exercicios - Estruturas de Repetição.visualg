algoritmo "Problema Pares Consecutivos"

var

  x, i, soma : inteiro

inicio

  escreval("Digite um número inteiro: ")
  leia(x)

  enquanto x <> 0 faca

    se (x mod 2) <> 0 entao
      x <- x + 1
    fimse

    soma <- 0
    para i de 1 ate 5 faca
      soma <- soma + x
      x <- x + 2
    fimpara

    escreval("Soma = ", soma)

    escreval("Digite um número inteiro: ")
    leia(x)

  fimenquanto

fimalgoritmo